rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users collection - stores profile info
    match /users/{userId} {
      // Allow any authenticated user to read/search users
      // This is needed for the "login by name/city" feature
      allow read: if isAuthenticated();
      
      // Allow creating own profile or updating it
      allow write: if isAuthenticated();
    }

    // UserData collection - stores tasks, notes, etc.
    // Keyed by {uid}_{key}
    match /userData/{docId} {
      // Allow any authenticated user to read/write data
      // We rely on the UID in the docId for privacy
      allow read, write: if isAuthenticated();
    }
    
    // Test collection for connection testing
    match /test/{docId} {
      allow read: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
